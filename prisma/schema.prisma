  courtFee        Float    @default(0) @map("court_fee")
  enforcementFee  Float    @default(0) @map("enforcement_fee")
  otherFee        Float    @default(0) @map("other_fee")
  updatedById     String?  @map("updated_by_id")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  case      Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("CaseFinancialUpdater", fields: [updatedById], references: [id])

  @@map("case_financials")
}

