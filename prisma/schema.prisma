// ── PHASE 13 — AUTOMATION ENGINE ─────────────────────────────────────────────

model AutomationRule {
  id           String    @id @default(cuid())
  name         String
  description  String?
  trigger      String    // CASE_CREATED | PAYMENT_CONFIRMED | PROMISE_BROKEN | etc.
  conditions   String    @default("[]")  // JSON: Condition[]
  actions      String    @default("[]")  // JSON: Action[]
  isActive     Boolean   @default(true)  @map("is_active")
  priority     Int       @default(0)
  testMode     Boolean   @default(false) @map("test_mode")
  lastRunAt    DateTime? @map("last_run_at")
  runCount     Int       @default(0)     @map("run_count")
  successCount Int       @default(0)     @map("success_count")
  failCount    Int       @default(0)     @map("fail_count")
  createdById  String    @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  createdBy  User                     @relation("AutomationRuleCreator", fields: [createdById], references: [id])
  executions AutomationExecutionLog[]

  @@index([trigger])
  @@index([isActive])
  @@map("automation_rules")
}

model AutomationExecutionLog {
  id           String   @id @default(cuid())
  ruleId       String   @map("rule_id")
  trigger      String
  triggerData  String   @default("{}") @map("trigger_data")
  success      Boolean
  actionsRun   String   @default("[]") @map("actions_run")
  errorMessage String?  @map("error_message")
  durationMs   Int?     @map("duration_ms")
  testMode     Boolean  @default(false) @map("test_mode")
  triggeredAt  DateTime @default(now()) @map("triggered_at")

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([triggeredAt])
  @@index([success])
  @@map("automation_execution_logs")
}

// ── PHASE 12 — RECOVERY & BILLING SYSTEM ────────────────────────────────────

model RecoveryPayment {
  id              String    @id @default(cuid())
  caseId          String?   @map("case_id")
  debtorId        String    @map("debtor_id")
  clientId        String?   @map("client_id")
  promiseId       String?   @map("promise_id")
  paymentType     String    @map("payment_type")
  amount          Float
  paymentDate     DateTime  @map("payment_date")
  paymentMethod   String    @map("payment_method")
  referenceNumber String?   @map("reference_number")
  proofUrl        String?   @map("proof_url")
  proofPublicId   String?   @map("proof_public_id")
  collectorId     String    @map("collector_id")
  status          String    @default("PENDING")
  note            String?
  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  case      Case?          @relation(fields: [caseId],    references: [id])
  debtor    Debtor         @relation(fields: [debtorId],  references: [id], onDelete: Cascade)
  client    ClientCompany? @relation(fields: [clientId],  references: [id])
  promise   PromiseToPay?  @relation(fields: [promiseId], references: [id])
  collector User           @relation("RecoveryCollector", fields: [collectorId],  references: [id])
  createdBy User           @relation("RecoveryCreator",   fields: [createdById],  references: [id])

  @@index([debtorId])
  @@index([caseId])
  @@index([collectorId])
  @@index([paymentDate])
  @@index([status])
  @@map("recovery_payments")
}

model CaseFinancial {
  id              String   @id @default(cuid())
  caseId          String   @unique @map("case_id")
  debtAmount      Float    @default(0) @map("debt_amount")
  collectedAmount Float    @default(0) @map("collected_amount")
