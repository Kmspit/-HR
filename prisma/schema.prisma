// HRFlow - Prisma Schema
// Database: SQLite (dev) / Turso (prod)
//
// เพิ่ม column ใหม่? อ่าน CONTRIBUTING.md ก่อนเสมอ — ต้องเพิ่มใน lib/ensure-db-schema.ts ด้วย
// (ไม่มี prisma/migrations — ระบบนี้ใช้ additive ALTER TABLE ของตัวเอง) ไม่งั้น production
// จะพังชั่วคราวเพราะ full-select ชนกับ column ที่ยังไม่ถูกสร้างจริงใน DB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── ENUMS ───────────────────────────────────────

enum Role {
  SUPER_ADMIN  // highest privilege — can do everything
  CEO          // chief executive — highest business authority
  MANAGER_HR   // legacy HR manager (backward compat)
  HR           // HR administrator
  MANAGER      // department manager — can approve leave/warnings
  TEAM_LEADER  // team lead — limited approvals
  ADMIN        // system admin
  EMPLOYEE     // regular employee
  LAWYER       // legal / weekly plans
  ENFORCEMENT  // enforcement officer — can issue warnings
  CLIENT       // Phase 5 — external client portal access
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  REJECTED
}

enum AttendanceStatus {
  NORMAL
  LATE
  ABSENT
  LEAVE
  OT
  HALF_DAY
  EARLY_LEAVE
}

enum LeaveType {
  SICK
  VACATION
  PERSONAL
  UNPAID
  MATERNITY
  ORDINATION
  FUNERAL
  WEDDING
  SPECIAL_HOLIDAY
}

enum DeviceStatus {
  ACTIVE
  PENDING_RESET
}

enum RequestStatus {
  PENDING
  ADMIN_APPROVED
  ADMIN_REJECTED
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAVE_REQUEST
  LEAVE_APPROVED
  LEAVE_REJECTED
  OUTSIDE_REQUEST
  OUTSIDE_APPROVED
  OUTSIDE_REJECTED
  REGISTER_REQUEST
  ACCOUNT_APPROVED
  ACCOUNT_REJECTED
  WARNING_ISSUED
  WEEKLY_PLAN_DUE
  WEEKLY_PLAN_APPROVED
  WEEKLY_PLAN_REJECTED
  DEVICE_RESET_REQUEST
  ANNOUNCEMENT
  SYSTEM
  FORGOT_SCAN_REQUEST
  FORGOT_SCAN_APPROVED
  FORGOT_SCAN_REJECTED
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REVISION
  // Phase 2 — deadline & reminder types
  TASK_DEADLINE_REMINDER
  TASK_OVERDUE
  TASK_COURT_REMINDER
  TASK_APPOINTMENT_REMINDER
  TASK_WAITING_DOC
  // Phase 3 — dependency & automation
  TASK_DEPENDENCY_UNBLOCKED
  TASK_AUTOMATION_TRIGGERED
  // Phase 4 — Case Document Center
  DOC_UPLOADED
  DOC_SIGNATURE_REQUIRED
  DOC_APPROVED
  DOC_REJECTED
  // Phase 7 — Case Finance
  EXPENSE_CLAIM_SUBMITTED
  EXPENSE_CLAIM_APPROVED
  EXPENSE_CLAIM_REJECTED
  EXPENSE_CLAIM_PAID
  // Phase 8 — Debt Collection CRM
  DEBT_APPOINTMENT_DUE
  DEBT_APPOINTMENT_MISSED
  DEBT_PAYMENT_RECEIVED
  // Phase 9 — Client CRM
  CONTRACT_EXPIRING
  // Phase 10 — Billing
  INVOICE_CREATED
  INVOICE_REMINDER
  INVOICE_OVERDUE
  // Phase 11 — Approval 2.0
  APPROVAL_REQUESTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  APPROVAL_REVISION
  SIGNATURE_REQUIRED
  APPROVAL_SIGNED
  // Phase 12 — Knowledge Base
  TRAINING_ASSIGNED
  TRAINING_OVERDUE
  SOP_UPDATED
  KNOWLEDGE_PUBLISHED
  // Phase 13 — Calendar
  CALENDAR_REMINDER
  // Phase 14 — LINE OA Automation 2.0
  LINE_APPROVAL_RESPONSE
  LINE_DAILY_SUMMARY
  // Phase 15 — Enterprise Security
  SECURITY_ALERT
  BACKUP_COMPLETED
  // Case Management
  CASE_CREATED
  CASE_ASSIGNED
  CASE_STATUS_CHANGED
  CASE_COURT_REMINDER
  CASE_RISK_ESCALATED
  CASE_NO_CONTACT_FOLLOWUP
  CASE_SLA_OVERDUE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  WAITING_REVIEW
  REVISION
  COMPLETED
  OVERDUE
  // Phase 1 — department workflow
  NEW
  ASSIGNED
  WAITING_DOC
  // Phase 2 — extended workflow
  WAITING_APPROVAL
  REJECTED
  CANCELLED
}

enum TaskType {
  OFFICE
  FIELD
  LEGAL
  DOCUMENT
  OTHER
  // ฝ่ายเร่งรัดหนี้
  DEBT_CALL
  DEBT_APPT
  DEBT_DOC
  DEBT_REPORT
  // ฝ่ายกฎหมาย
  LEGAL_DRAFT
  LEGAL_FILE
  LEGAL_COURT_PREP
  LEGAL_HEARING
  // ฝ่ายสืบทรัพย์
  ASSET_CHECK
  ASSET_SURVEY
  ASSET_REPORT
  // ฝ่ายบังคับคดี
  ENF_FILE
  ENF_SEIZE
  ENF_SUMMARY
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  PASSWORD_RESET
  // Phase 15 — Security
  EXPORT
  SECURITY_CHANGE
}

enum HolidayType {
  SATURDAY
  SUNDAY
  PUBLIC_HOLIDAY
  COMPANY_HOLIDAY
}

enum CaseType {
  DEBT_COLLECTION
  LEGAL
  COURT
  ASSET_INVESTIGATION
  ENFORCEMENT
  INTERNAL_LEGAL
}

enum CaseStatus {
  NEW
  ASSIGNED
  INVESTIGATING
  NEGOTIATING
  WAITING_DOCUMENT
  FILED
  COURT_PROCESS
  ENFORCEMENT
  SETTLED
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CourtType {
  CIVIL
  CRIMINAL
  BANKRUPTCY
  EXECUTION
  LABOR
  ADMINISTRATIVE
  OTHER
}

enum AppointmentType {
  HEARING
  MEDIATION
  FILING
  WITNESS
  JUDGEMENT
  ENFORCEMENT
  NEGOTIATION
  OTHER
}

enum CourtEventStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  MISSED
  CANCELLED
  RESCHEDULED
}

enum CourtPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// ── COMPANY BRANCH ──────────────────────────────

model CompanyBranch {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  nameEn       String?
  address      String?
  phone        String?
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  lat             Float?
  lng             Float?
  radiusMeters    Float    @default(100)
  googleMapPlaceId String?
  createdAt       DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  divisions   Division[]
  departments Department[]
  sections    Section[]
  holidays    CompanyHoliday[]
  attendances Attendance[]

  @@map("company_branches")
}

// ── COMPANY HOLIDAYS ───────────────────────────

model CompanyHoliday {
  id              String      @id @default(cuid())
  holidayName     String
  holidayDate     DateTime
  holidayType     HolidayType
  repeatEveryYear Boolean     @default(false)
  branchId        String?
  createdById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  branch    CompanyBranch? @relation(fields: [branchId], references: [id])
  createdBy User?          @relation("HolidayCreator", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([holidayDate])
  @@map("company_holidays")
}

// ── ORG STRUCTURE (ฝ่าย / แผนก / ส่วนงาน) ─────

model Division {
  id        String   @id @default(cuid())
  branchId  String
  code      String
  name      String
  nameEn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      CompanyBranch @relation(fields: [branchId], references: [id])
  departments Department[]
  users       User[]

  @@unique([branchId, code])
  @@map("divisions")
}

model Department {
  id         String   @id @default(cuid())
  branchId   String
  divisionId String
  code       String
  name       String
  nameEn     String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch   CompanyBranch @relation(fields: [branchId], references: [id])
  division Division      @relation(fields: [divisionId], references: [id])
  sections Section[]
  users    User[]

  @@unique([divisionId, code])
  @@map("departments")
}

model Section {
  id           String   @id @default(cuid())
  branchId     String
  departmentId String
  code         String
  name         String
  nameEn       String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch     CompanyBranch @relation(fields: [branchId], references: [id])
  department Department    @relation(fields: [departmentId], references: [id])
  users      User[]

  @@unique([departmentId, code])
  @@map("sections")
}

// ── USER ────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  employeeId       String?    @unique
  passwordHash     String
  name             String
  nameEn           String?
  nickname         String?
  prefix           String?
  phone            String?    @unique
  birthDate        DateTime?
  address          String?
  addressIdCard    String?
  nationalId       String?    @unique
  profileImage              String?
  profileImageBase64        String? // deprecated — migrate to Cloudinary
  profileCloudinaryPublicId String?
  profileSecureUrl          String?
  employeeType     String?    @default("permanent_employee")
  managerId        String?
  teamLeaderId     String?
  role             Role       @default(EMPLOYEE)
  status           UserStatus @default(PENDING)
  department       String?
  divisionId       String?
  departmentId     String?
  sectionId        String?
  position         String?
  baseSalary       Float?
  startDate        DateTime?
  socialSecurity   Boolean    @default(true)
  lineId               String?
  lineUserId           String?    @unique
  lineDisplayName      String?
  lineNotifSettings    String?    @map("line_notif_settings")
  // Phase 15 — Security
  lockedUntil          DateTime?  @map("locked_until")
  passwordChangedAt    DateTime?  @map("password_changed_at")
  isCoworker           Boolean    @default(false)
  approvedById     String?
  approvedAt       DateTime?
  branchId         String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  branch          CompanyBranch?      @relation(fields: [branchId], references: [id])
  division        Division?           @relation(fields: [divisionId], references: [id])
  orgDepartment   Department?         @relation(fields: [departmentId], references: [id])
  section         Section?            @relation(fields: [sectionId], references: [id])
  approvedBy      User?               @relation("UserApproval", fields: [approvedById], references: [id])
  approvedUsers   User[]              @relation("UserApproval")
  manager         User?               @relation("UserManager", fields: [managerId], references: [id])
  managedUsers    User[]              @relation("UserManager")
  teamLeader      User?               @relation("UserTeamLeader", fields: [teamLeaderId], references: [id])
  teamMembers     User[]              @relation("UserTeamLeader")
  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  outsideRequests OutsideWorkRequest[]
  outsideRequestsDeleted OutsideWorkRequest[] @relation("OutsideWorkDeletedBy")
  outsideWorkAssignments OutsideWorkAssignee[] @relation("OutsideWorkAssignee")
  weeklyPlans     WeeklyLawyerPlan[]
  approvalActions ApprovalHistory[]   @relation("ApprovedBy")
  notifications   Notification[]
  auditLogs       AuditLog[]          @relation("AuditUser")
  auditActions    AuditLog[]          @relation("AuditActor")
  leaveBalances   LeaveBalance[]
  warnings         Warning[]
  warningsIssued   Warning[]           @relation("WarningsIssued")
  warningsApproved Warning[]           @relation("WarningApprovedBy")
  warningsRejected Warning[]           @relation("WarningRejectedBy")
  payrolls        Payroll[]
  holidaysCreated CompanyHoliday[]  @relation("HolidayCreator")
  savedWorkPlaces     SavedWorkPlace[]
  device              UserDevice?
  faceProfile         UserFaceProfile?
  faceLogs            AttendanceFaceLog[]
  chainStepsAssigned       ApprovalChainStep[]       @relation("ChainStepApprover")
  leaveStepActions         LeaveApprovalStep[]       @relation("LeaveStepActor")
  outsideWorkStepActions   OutsideWorkApprovalStep[] @relation("OutsideStepActor")
  weeklyPlanStepActions    WeeklyPlanApprovalStep[]  @relation("WeeklyPlanStepActor")
  forgotScanStepActions    ForgotScanApprovalStep[]  @relation("ForgotScanStepActor")
  salarySlips         SalarySlip[]
  taxHistories        TaxHistory[]
  probationEvaluation      ProbationEvaluation?
  probationEvaluationsGiven ProbationEvaluation[] @relation("ProbationEvaluator")
  documentRequests         DocumentRequest[]
  documentRequestsHandled  DocumentRequest[]      @relation("DocumentHandler")
  forgotScanRequests        ForgotScanRequest[]   @relation("ForgotScanUser")
  forgotScanSupervisedReqs  ForgotScanRequest[]   @relation("ForgotScanSupervisor")
  forgotScanApprovedHR      ForgotScanRequest[]   @relation("ForgotScanHR")
  assignedTasks             TaskAssignment[]       @relation("TaskAssignee")
  createdTasks              TaskAssignment[]       @relation("TaskAssigner")
  reviewedTasks             TaskAssignment[]       @relation("TaskReviewer")
  taskAttachments           TaskAttachment[]       @relation("TaskAttachmentUploader")
  taskComments              TaskComment[]          @relation("TaskCommentAuthor")
  completedChecklistItems   TaskChecklist[]        @relation("TaskChecklistCompleter")
  taskTimelines             TaskTimeline[]         @relation("TaskTimelineActor")
  taskTemplatesCreated      TaskTemplate[]         @relation("TemplateCreator")
  // Phase 4 — Case Document Center
  caseDocsUploaded          CaseDocument[]         @relation("CaseDocUploader")
  caseDocsAssigned          CaseDocument[]         @relation("CaseDocAssignee")
  caseDocFiles              CaseDocumentFile[]     @relation("CaseDocFileUploader")
  caseDocSigns              CaseDocumentSignature[] @relation("CaseDocSigner")
  caseDocVersions           CaseDocumentVersion[]  @relation("CaseDocVersioner")
  // Phase 5 — Client Portal
  clientTasks               TaskAssignment[]       @relation("TaskClient")
  clientDocs                CaseDocument[]         @relation("DocClient")
  clientMsgsAsClient        ClientMessage[]        @relation("ClientMessages")
  clientMsgsAsSender        ClientMessage[]        @relation("MessageSender")
  caseStatusChanges         CaseStatusHistory[]    @relation("StatusHistoryChanger")
  // Phase 7 — Case Finance
  caseIncomesCreated        CaseIncome[]           @relation("CaseIncomeCreator")
  caseExpensesAsEmp         CaseExpense[]          @relation("CaseExpenseEmployee")
  caseExpensesCreated       CaseExpense[]          @relation("CaseExpenseCreator")
  expenseClaimsSubmitted    ExpenseClaim[]         @relation("ClaimSubmitter")
  // Phase 8 — Debt Collection CRM
  debtorsAssigned           Debtor[]               @relation("DebtorAssignee")
  debtorsCreated            Debtor[]               @relation("DebtorCreator")
  debtFollowUps             DebtFollowUp[]         @relation("FollowUpPerformer")
  debtPaymentsReceived      DebtPayment[]          @relation("PaymentReceiver")
  debtPaymentsCreated       DebtPayment[]          @relation("PaymentCreator")
  paymentAppointmentsCreated PaymentAppointment[]  @relation("AppointmentCreator")
  debtorFilesCreated        DebtorFile[]           @relation("DebtorFileCreator")
  debtorContactsPerformed   DebtorContact[]        @relation("ContactPerformer")
  promisesCreated           PromiseToPay[]         @relation("PromiseCreator")
  // Phase 12 — Recovery
  recoveryPaymentsCollected RecoveryPayment[]      @relation("RecoveryCollector")
  recoveryPaymentsCreated   RecoveryPayment[]      @relation("RecoveryCreator")
  // Phase 13 — Automation
  automationRulesCreated    AutomationRule[]       @relation("AutomationRuleCreator")
  // Phase 9 — Client CRM
  clientCompaniesCreated    ClientCompany[]        @relation("ClientCompanyCreator")
  clientContractsCreated    ClientContract[]       @relation("ClientContractCreator")
  clientSlaRecords          ClientSlaRecord[]      @relation("SlaRecordCreator")
  clientCompanyFilesCreated ClientCompanyFile[]    @relation("ClientCompanyFileCreator")
  // Phase 10 — Billing
  invoicesCreated           BillingInvoice[]       @relation("InvoiceCreator")
  invoicesApproved          BillingInvoice[]       @relation("InvoiceApprover")
  billingPaymentsReceived   BillingPayment[]       @relation("BillingPaymentReceiver")
  billingPaymentsCreated    BillingPayment[]       @relation("BillingPaymentCreator")
  billingReceiptsCreated    BillingReceipt[]       @relation("BillingReceiptCreator")
  // Phase 11 — Approval 2.0
  activityLogs              ActivityLog[]          @relation("ActivityLogActor")
  digitalSignatures         DigitalSignature[]     @relation("DigitalSignatureUser")
  approvalRequestsMade      ApprovalRequest[]      @relation("ApprovalRequester")
  approvalStepsAssigned     ApprovalRequestStep[]  @relation("StepApprover")
  approvalStepActions       ApprovalRequestStep[]  @relation("StepActor")
  // Phase 12 — Knowledge Base
  knowledgeArticlesCreated  KnowledgeArticle[]     @relation("KnowledgeCreator")
  knowledgeArticlesApproved KnowledgeArticle[]     @relation("KnowledgeApprover")
  sopDocumentsCreated       SopDocument[]          @relation("SopCreator")
  sopDocumentsApproved      SopDocument[]          @relation("SopApprover")
  sopVersionsCreated        SopVersion[]           @relation("SopVersionCreator")
  trainingModulesCreated    TrainingModule[]       @relation("TrainingCreator")
  trainingEnrollments       TrainingEnrollment[]   @relation("TrainingEnrollee")
  quizAttempts              QuizAttempt[]          @relation("QuizAttemptUser")
  // Phase 13 — Calendar
  calendarEvents            CalendarEvent[]        @relation("CalendarEventCreator")
  // Phase 15 — Security
  loginAttempts             LoginAttempt[]
  securityEvents            SecurityEvent[]
  deviceSessions            DeviceSession[]
  otpCodes                  OtpCode[]
  twoFactorSetup            TwoFactorSetup?
  // Case Management
  casesCreated              Case[]               @relation("CaseCreator")
  casesAssigned             Case[]               @relation("CaseAssignee")
  caseCourtItems            CaseCourt[]          @relation("CaseCourtCreator")
  caseTimelines             CaseTimeline[]       @relation("CaseTimelineActor")
  caseTemplates             CaseTemplate[]       @relation("CaseTemplateCreator")
  caseChecklistDone         CaseChecklist[]      @relation("CaseChecklistDoneBy")
  caseDebtorActivities      CaseDebtorActivity[] @relation("CaseDebtorActivityActor")
  caseFinancialUpdates      CaseFinancial[]      @relation("CaseFinancialUpdater")
  // Phase 14 — Court Calendar
  courtEventsCreated        CourtEvent[]         @relation("CourtEventCreator")
  courtEventsAssigned       CourtEvent[]         @relation("CourtEventLawyer")

  @@map("users")
}

// ── FACE RECOGNITION (ลงทะเบียนใบหน้า 1 ครั้ง) ──

// employee_face_profiles (physical table user_face_profiles — ลงทะเบียนใบหน้า)
model UserFaceProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  employeeId          String?
  encryptedDescriptor String
  faceEmbedding       String? // alias path; ใช้ encryptedDescriptor เป็นหลัก
  cloudinaryPublicId  String?
  faceImageUrl        String?
  secureUrl           String?
  isActive            Boolean  @default(true)
  modelVersion        String   @default("face-api-tiny-v1")
  sampleCount         Int      @default(1)
  registeredAt        DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("user_face_profiles")
}

model AttendanceFaceLog {
  id              String   @id @default(cuid())
  userId          String
  attendanceId    String?
  action          String
  method          String
  matched         Boolean  @default(false)
  matchScore      Float?
  livenessScore   Float?
  spoofFlags      String?
  failureReason   String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("attendance_face_logs")
}

// ── ATTENDANCE LINE NOTIFY (ส่งเข้า LINE OA ของ HR) ──

model AttendanceLineNotifyLog {
  id             String    @id @default(cuid())
  employeeUserId String
  employeeId     String?   // รหัสพนักงาน (EMP001)
  hrLineUserId   String
  eventType      String
  scanType       String?   // checkin | checkout | lunch-out | lunch-in
  attendanceId   String?
  faceLogId      String?
  faceScanId     String?
  messageText    String
  photoUrl       String?   // secure Cloudinary URL สำหรับ LINE image (legacy)
  imageUrl       String?   // secure Cloudinary URL สำหรับ LINE image
  status         String    @default("pending") // lineStatus: pending | sent | failed
  failedReason   String?
  retryCount     Int       @default(0)
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([employeeUserId, createdAt])
  @@index([attendanceId, eventType, status])
  @@map("attendance_line_notify_logs")
}

// ── ATTENDANCE FACE SCAN (metadata + Cloudinary — ไม่เก็บ blob ใน DB) ──

model AttendanceFaceScan {
  id                 String   @id @default(cuid())
  userId             String
  employeeId         String?
  companyId          String?
  branchId           String?
  attendanceId       String?
  faceLogId          String?
  scanType           String
  scanTime           DateTime @default(now())
  cloudinaryPublicId String?
  imageUrl           String?
  secureUrl          String?
  format             String?
  fileSize           Int?
  width              Int?
  height             Int?
  confidenceScore    Float?
  matchScore         Float?
  livenessScore      Float?
  faceMatched        Boolean  @default(true)
  matched            Boolean  @default(true)
  storageProvider    String   @default("cloudinary")
  objectKey          String?
  imageMime          String   @default("image/jpeg")
  imageData          String   @default("")
  locationName       String?
  location           String?
  address            String?
  lat                Float?
  lng                Float?
  latitude           Float?
  longitude          Float?
  deviceInfo         String?
  createdAt          DateTime @default(now())

  @@index([userId, scanTime])
  @@index([employeeId, scanTime])
  @@index([scanType, scanTime])
  @@index([attendanceId])
  @@index([cloudinaryPublicId])
  @@map("attendance_face_scans")
}

// ── SAVED WORK PLACES (ชื่อสถานที่ — ไม่ผูก GPS) ──

model SavedWorkPlace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("saved_work_places")
}

// ── DEVICE BINDING (1 user = 1 device) ──

model UserDevice {
  id               String       @id @default(cuid())
  userId           String       @unique
  deviceKey        String
  deviceLabel      String?
  status           DeviceStatus @default(ACTIVE)
  registeredAt     DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  resetRequestedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_devices")
}

// ── ATTENDANCE ──────────────────────────────────

model Attendance {
  id          String           @id @default(cuid())
  userId      String
  date        DateTime
  /** รอบการทำงานในวันเดียวกัน (1 = เข้างานครั้งแรก, 2 = ออกไปลูกค้าแล้วกลับมา ฯลฯ) */
  sessionIndex Int             @default(1)
  checkIn     DateTime?
  checkOut    DateTime?
  lunchOut    DateTime?
  lunchIn     DateTime?
  lat         Float?
  lng         Float?
  address          String?
  workPlaceName    String?
  checkInLat           Float?
  checkInLng           Float?
  checkInAddress       String?
  checkInWorkPlaceName String?
  checkOutLat           Float?
  checkOutLng           Float?
  checkOutAddress       String?
  checkOutWorkPlaceName String?
  photoUrl         String?
  checkOutPhotoUrl String?
  lunchOutPhotoUrl String?
  lunchInPhotoUrl  String?
  /// Cloudinary public_id of the latest attendance photo (checkin by default)
  imagePublicId    String? @map("image_public_id")
  /// Cloudinary secure_url of the latest attendance photo
  imageUrl         String? @map("image_url")
  isOutside        Boolean          @default(false)
  status           AttendanceStatus @default(NORMAL)
  /** อนุมัติอัตโนมัติหลังสแกนใบหน้าสำเร็จ — ไม่ต้องรอ HR */
  approved         Boolean          @default(true)
  /** completed = บันทึกลงเวลาแล้วทันที */
  attendanceStatus String           @default("completed")
  dayOfWeek        Int?
  workMinutes      Int              @default(0)
  leaveType        LeaveType?
  lateMinutes      Int              @default(0)
  earlyLeaveMinutes Int             @default(0)
  lunchOverMinutes  Int              @default(0)
  checkInDistanceM     Float?   // distance from company geofence center at check-in (meters)
  gpsAccuracy          Float?   // GPS accuracy in meters as reported by device
  gpsFlags             String?  // comma-separated spoof/quality flags for HR review
  deviceInfo           String?  // JSON { ua, platform, isMobile }
  outsideWorkRequestId String?  // approved OutsideWorkRequest that authorized this outside check-in
  weeklyPlanDayId      String?  @map("weekly_plan_day_id")   // WeeklyPlanDay that authorized/matched this outside check-in
  plannedLat           Float?   @map("planned_lat")
  plannedLng           Float?   @map("planned_lng")
  plannedPlace         String?  @map("planned_place")
  locationDistance     Float?   @map("location_distance")    // meters between planned and actual GPS
  locationStatus       String?  @map("location_status")      // matched | mismatch | no_gps_plan | no_plan
  branchId             String?  // สาขาที่ใช้เช็คอิน
  note             String?
  editedById       String?
  autoCheckout     Boolean          @default(false) // ระบบ auto checkout หลัง 22:00
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user   User            @relation(fields: [userId], references: [id])
  branch CompanyBranch?  @relation(fields: [branchId], references: [id])

  @@unique([userId, date, sessionIndex])
  @@index([userId, date])
  @@index([branchId, date])
  @@map("attendances")
}

// ── LEAVE ───────────────────────────────────────

model LeaveRequest {
  id               String        @id @default(cuid())
  userId           String
  type             LeaveType
  startDate        DateTime
  endDate          DateTime
  days             Int
  reason           String
  attachmentUrl    String?
  status           RequestStatus @default(PENDING)
  chainConfigId    String?       // null = legacy 2-step flow
  currentStepOrder Int           @default(0) // 0 = legacy, 1+ = active chain step
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  approvals    ApprovalHistory[]
  chainConfig  ApprovalChainConfig? @relation("LeaveChain", fields: [chainConfigId], references: [id])
  stepLogs     LeaveApprovalStep[]

  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

model LeaveBalance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  sick      Int      @default(30)
  vacation  Int      @default(6)
  personal  Int      @default(3)
  unpaid    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year])
  @@map("leave_balances")
}

// ── OUTSIDE WORK ────────────────────────────────

model OutsideWorkRequest {
  id             String        @id @default(cuid())
  userId         String
  date           DateTime
  startTime      String
  endTime        String
  place          String
  purpose        String
  client         String?
  note           String?
  googleMapsUrl  String?       @map("google_maps_url")
  attachmentUrl  String?       @map("attachment_url")
  attachmentName String?       @map("attachment_name")
  approvalStatus String?       @map("approval_status")
  employeeName   String?       @map("employee_name")
  ownerName      String?       @map("owner_name")
  workType       String?       @map("work_type")
  distance       Float?
  distanceLimit  Float?        @map("distance_limit")
  routeType      String?       @map("route_type")
  // ── ฟอร์มบริษัท (ฉ.2) ───────────────────────────────────────
  timeSlot       String?       @map("time_slot")      // เช้า / บ่าย / เต็มวัน
  caseNumber     String?       @map("case_number")    // หมายเลขคดีดำ
  productWork    String?       @map("product_work")   // งานโปรดักส์ (legacy free-text)
  productCategory String?      @map("product_category") // หมวดหมู่หลัก เช่น เช่าซื้อรถยนต์
  productType    String?       @map("product_type")   // ประเภทย่อย เช่น รถยนต์มือสอง
  workBranch     String?       @map("work_branch")    // งานของสาขาไหน
  caseCount      Int?          @map("case_count")     // จำนวนคดีที่ไปดำเนินการ
  adminChecked   String?       @map("admin_checked")   // มี / ไม่มี
  supervisedBy   String?       @map("supervised_by")   // ผู้สั่งงาน
  documentNumber String?       @unique @map("document_number") // OW-2567-001
  clientCompanyId String?      @map("client_company_id") // เลือกจาก ClientCompany CRM ผ่าน dropdown กรองในตาราง Excel-grid (optional — record เก่าไม่มีค่านี้)
  status           RequestStatus @default(PENDING)
  chainConfigId    String?
  currentStepOrder Int           @default(0)
  deletedAt        DateTime?     @map("deleted_at")    // soft-delete — เก็บร่องรอยไว้ตรวจสอบย้อนหลัง (ข้อมูลงานคดี)
  deletedById      String?       @map("deleted_by_id") // ใครเป็นคนลบ (audit)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user          User                      @relation(fields: [userId], references: [id])
  approvals     ApprovalHistory[]
  chainConfig   ApprovalChainConfig?      @relation("OutsideChain", fields: [chainConfigId], references: [id])
  stepLogs      OutsideWorkApprovalStep[]
  clientCompany ClientCompany?            @relation(fields: [clientCompanyId], references: [id], onDelete: SetNull)
  deletedBy     User?                     @relation("OutsideWorkDeletedBy", fields: [deletedById], references: [id])
  assignees     OutsideWorkAssignee[]

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
  @@map("outside_work_requests")
}

/** พนักงานที่รับผิดชอบงานโปรดักส์ (หลายคนต่อ 1 คำขอออกนอกสถานที่) */
model OutsideWorkAssignee {
  id                   String   @id @default(cuid())
  outsideWorkRequestId String   @map("outside_work_request_id")
  userId               String   @map("user_id")
  createdAt            DateTime @default(now()) @map("created_at")

  outsideWorkRequest OutsideWorkRequest @relation(fields: [outsideWorkRequestId], references: [id], onDelete: Cascade)
  user               User               @relation("OutsideWorkAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([outsideWorkRequestId, userId])
  @@index([userId])
  @@map("outside_work_assignees")
}

// ── WEEKLY LAWYER PLAN ──────────────────────────

model WeeklyLawyerPlan {
  id        String        @id @default(cuid())
  lawyerId  String
  weekStart DateTime
  weekEnd   DateTime
  deadline  DateTime
  status         RequestStatus @default(PENDING)
  approvalStatus String?       @map("approval_status")   // null = legacy record
  supervisorComment String?    @map("supervisor_comment")
  executiveComment  String?    @map("executive_comment")
  chainConfigId     String?    @map("chain_config_id")
  currentStepOrder  Int        @default(0) @map("current_step_order")
  note      String?
  isLate    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lawyer    User              @relation(fields: [lawyerId], references: [id])
  days      WeeklyPlanDay[]
  approvals ApprovalHistory[]
  chain     ApprovalChainConfig? @relation("WeeklyPlanChain", fields: [chainConfigId], references: [id])
  stepLogs  WeeklyPlanApprovalStep[]

  @@map("weekly_lawyer_plans")
}

model WeeklyPlanDay {
  id        String   @id @default(cuid())
  planId    String
  dayOfWeek Int
  date      DateTime
  startTime String?
  endTime   String?
  place     String?
  purpose   String?
  client    String?
  note      String?
  lat       Float?   @map("plan_lat")
  lng       Float?   @map("plan_lng")

  plan WeeklyLawyerPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("weekly_plan_days")
}

// ── APPROVAL HISTORY ────────────────────────────

model ApprovalHistory {
  id               String   @id @default(cuid())
  approvedById     String
  action           String
  reason           String?
  step             Int
  ip               String?
  createdAt        DateTime @default(now())
  leaveRequestId   String?
  outsideRequestId String?
  weeklyPlanId     String?

  approvedBy     User                @relation("ApprovedBy", fields: [approvedById], references: [id])
  leaveRequest   LeaveRequest?       @relation(fields: [leaveRequestId], references: [id])
  outsideRequest OutsideWorkRequest? @relation(fields: [outsideRequestId], references: [id])
  weeklyPlan     WeeklyLawyerPlan?   @relation(fields: [weeklyPlanId], references: [id])

  @@map("approval_histories")
}

// ── NOTIFICATIONS ───────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  taskId    String?          @map("task_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ── AUDIT LOGS ──────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  targetId   String?
  targetType String?
  action     AuditAction
  before     String?
  after      String?
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  actor  User  @relation("AuditActor", fields: [actorId], references: [id])
  target User? @relation("AuditUser", fields: [targetId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@map("audit_logs")
}

// ── WARNINGS ────────────────────────────────────

model Warning {
  id          String   @id @default(cuid())
  userId      String
  issuedById  String
  level       Int      @default(1)
  reason      String
  description String?
  fileUrl     String?
  pdfBase64   String?
  sentToLine           Boolean   @default(false)
  lineDeliveryStatus   String?   // pending | sent | failed
  lineSentAt           DateTime?
  lineUserId           String?
  lineErrorMessage     String?
  isAuto               Boolean   @default(false)
  month       Int?
  year        Int?
  // ── approval flow ────────────────────────────────
  // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED | ARCHIVED
  status         String    @default("APPROVED")
  expiredAt      DateTime?  // auto: createdAt + 12 months
  approvedById   String?
  approvedAt     DateTime?
  rejectedById   String?
  rejectedAt     DateTime?
  rejectedReason String?
  archivedAt     DateTime?
  approvalNote   String?
  lateCount      Int?       // late occurrences that triggered this auto-warning
  createdAt   DateTime @default(now())

  user       User  @relation(fields: [userId], references: [id])
  issuedBy   User  @relation("WarningsIssued",    fields: [issuedById],   references: [id])
  approvedBy User? @relation("WarningApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User? @relation("WarningRejectedBy", fields: [rejectedById], references: [id])

  @@map("warnings")
}

// ── WARNING RULES ───────────────────────────────

model WarningRule {
  id              String   @id @default(cuid())
  level           Int
  name            String
  lateThreshold   Int?
  absentThreshold Int?
  periodDays      Int      @default(30)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@map("warning_rules")
}

// ── PAYROLL ─────────────────────────────────────

model Payroll {
  id              String    @id @default(cuid())
  userId          String
  month           Int
  year            Int
  baseSalary      Float
  lateDeduction   Float     @default(0)
  absentDeduction Float     @default(0)
  unpaidLeave     Float     @default(0)
  socialSecurity  Float     @default(0)
  otherDeduction  Float     @default(0)
  otherAddition   Float     @default(0)
  netSalary       Float
  lateDays        Int       @default(0)
  absentDays      Int       @default(0)
  lateMinutes     Int       @default(0)
  lateBillableMinutes Int   @default(0)
  lateDeductionDetail String?
  taxDeduction    Float     @default(0)
  taxDetail       String?   // JSON: { annualGross, taxableIncome, annualTax, monthlyWithholding }
  status          String    @default("DRAFT")
  slipSentAt      DateTime?
  payslipSentAt     DateTime?
  payslipSentVia    String?   // 'LINE' | 'EMAIL'
  payslipSentStatus String?   // 'SUCCESS' | 'FAILED' | 'PENDING'
  payslipSentError  String?
  payslipCloudinaryPublicId String?
  approvedById    String?
  approvedAt      DateTime?
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  salarySlip SalarySlip?

  @@unique([userId, month, year])
  @@map("payrolls")
}

// ── SALARY SLIPS ────────────────────────────────

model SalarySlip {
  id        String   @id @default(cuid())
  payrollId String   @unique
  userId    String
  month     Int
  year      Int
  pdfBase64 String?
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("salary_slips")
}

// ── TAX HISTORY ──────────────────────────────────

model TaxHistory {
  id                String   @id @default(cuid())
  userId            String
  month             Int
  year              Int
  annualGross       Float
  incomeDeduction   Float
  personalAllowance Float
  taxableIncome     Float
  annualTax         Float
  monthlyTax        Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("tax_history")
}

// ── PROBATION EVALUATION ─────────────────────────

model ProbationEvaluation {
  id            String    @id @default(cuid())
  userId        String    @unique
  result        String    @default("PENDING")
  notes         String?
  evaluatedById String?
  evaluatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluatedBy User? @relation("ProbationEvaluator", fields: [evaluatedById], references: [id])

  @@map("probation_evaluations")
}

// ── DOCUMENT REQUESTS ────────────────────────────

model DocumentRequest {
  id          String    @id @default(cuid())
  userId      String
  type        String
  purpose     String?
  status      String    @default("PENDING")
  notes       String?
  handledById String?
  handledAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  handledBy User? @relation("DocumentHandler", fields: [handledById], references: [id])

  @@map("document_requests")
}

// ── COMPANY RULES ───────────────────────────────

model CompanyRule {
  id          String   @id @default(cuid())
  title       String
  content     String?
  fileUrl     String?
  category    String   @default("general")
  version     String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdById String
  updatedAt   DateTime @updatedAt

  @@map("company_rules")
}

// ── ANNOUNCEMENTS ───────────────────────────────

model Announcement {
  id                 String   @id @default(cuid())
  title              String
  body               String
  type               String   @default("GENERAL")
  targetType         String   @default("ALL")
  targetIds          String?
  publishAt          DateTime @default(now())
  readByIds          String?
  isArchived         Boolean  @default(false)
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  attachmentName     String?
  attachmentUrl      String?
  attachmentType     String?
  attachmentPublicId String?

  @@index([createdAt])
  @@index([isArchived, publishAt])
  @@map("announcements")
}

// ── APPROVAL CHAIN (multi-step leave workflow) ───

model ApprovalChainConfig {
  id          String   @id @default(cuid())
  name        String
  description String?
  entityType  String   @default("LEAVE") // LEAVE | OUTSIDE_WORK
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // auto-apply to new requests of entityType
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps           ApprovalChainStep[]
  leaveRequests   LeaveRequest[]         @relation("LeaveChain")
  outsideRequests OutsideWorkRequest[] @relation("OutsideChain")
  weeklyPlans     WeeklyLawyerPlan[]     @relation("WeeklyPlanChain")
  forgotScanRequests ForgotScanRequest[] @relation("ForgotScanChain")

  @@map("approval_chain_configs")
}

model ApprovalChainStep {
  id           String   @id @default(cuid())
  chainId      String
  stepOrder    Int      // 1, 2, 3 …
  stepName     String   // "หัวหน้าทีม", "ผู้จัดการ", "HR อนุมัติ"
  approverRole Role?    // role ที่มีสิทธิ์อนุมัติขั้นนี้ (null = ใช้ approverId แทน)
  approverId   String?  // ระบุ user เฉพาะเจาะจง (optional override)
  canSkip      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chain            ApprovalChainConfig       @relation(fields: [chainId], references: [id], onDelete: Cascade)
  approver         User?                     @relation("ChainStepApprover", fields: [approverId], references: [id])
  stepLogs         LeaveApprovalStep[]
  outsideStepLogs  OutsideWorkApprovalStep[]
  weeklyStepLogs   WeeklyPlanApprovalStep[]
  forgotScanStepLogs ForgotScanApprovalStep[]

  @@unique([chainId, stepOrder])
  @@map("approval_chain_steps")
}

// approval_steps table — instance per leave request (tracks status per step)
model LeaveApprovalStep {
  id              String             @id @default(cuid())
  leaveRequestId  String
  chainStepId     String
  stepOrder       Int
  stepName        String
  approverRole    Role?
  approverId      String?
  status          ApprovalStepStatus @default(PENDING)
  actorId         String?            // user who acted
  comment         String?
  ip              String?
  actedAt         DateTime?
  createdAt       DateTime           @default(now())

  leaveRequest  LeaveRequest      @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  chainStep     ApprovalChainStep @relation(fields: [chainStepId], references: [id])
  actor         User?             @relation("LeaveStepActor", fields: [actorId], references: [id])

  @@index([leaveRequestId])
  @@map("leave_approval_steps")
}

model OutsideWorkApprovalStep {
  id           String             @id @default(cuid())
  requestId    String
  chainStepId  String
  stepOrder    Int
  stepName     String
  approverRole Role?
  approverId   String?
  status       ApprovalStepStatus @default(PENDING)
  actorId      String?
  comment      String?
  ip           String?
  actedAt      DateTime?
  createdAt    DateTime           @default(now())

  request   OutsideWorkRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  chainStep ApprovalChainStep  @relation(fields: [chainStepId], references: [id])
  actor     User?              @relation("OutsideStepActor", fields: [actorId], references: [id])

  @@index([requestId])
  @@map("outside_work_approval_steps")
}

model WeeklyPlanApprovalStep {
  id           String             @id @default(cuid())
  weeklyPlanId String             @map("weekly_plan_id")
  chainStepId  String             @map("chain_step_id")
  stepOrder    Int
  stepName     String
  approverRole Role?
  approverId   String?
  status       ApprovalStepStatus @default(PENDING)
  actorId      String?
  comment      String?
  ip           String?
  actedAt      DateTime?
  createdAt    DateTime           @default(now())

  plan      WeeklyLawyerPlan  @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  chainStep ApprovalChainStep @relation(fields: [chainStepId], references: [id])
  actor     User?             @relation("WeeklyPlanStepActor", fields: [actorId], references: [id])

  @@index([weeklyPlanId])
  @@map("weekly_plan_approval_steps")
}

model ForgotScanApprovalStep {
  id           String             @id @default(cuid())
  forgotScanId String             @map("forgot_scan_id")
  chainStepId  String             @map("chain_step_id")
  stepOrder    Int
  stepName     String
  approverRole Role?
  approverId   String?
  status       ApprovalStepStatus @default(PENDING)
  actorId      String?
  comment      String?
  ip           String?
  actedAt      DateTime?
  createdAt    DateTime           @default(now())

  request   ForgotScanRequest @relation(fields: [forgotScanId], references: [id], onDelete: Cascade)
  chainStep ApprovalChainStep @relation(fields: [chainStepId], references: [id])
  actor     User?             @relation("ForgotScanStepActor", fields: [actorId], references: [id])

  @@index([forgotScanId])
  @@map("forgot_scan_approval_steps")
}

// ── COMPANY SETTINGS ────────────────────────────

model CompanySettings {
  id               String   @id @default("singleton")
  companyName      String   @default("บริษัท เค เอ็ม เซอร์วิส พลัส จำกัด")
  companyNameEn    String?
  officeAddress    String?
  logoUrl          String?
  workStartTime    String   @default("08:30")
  workEndTime      String   @default("17:30")
  lunchReturnTime  String   @default("13:00")
  lateGraceMin     Int      @default(5)
  sickDaysYear     Int      @default(30)
  vacationDaysYear Int      @default(6)
  personalDaysYear Int      @default(3)
  lineChannelId    String?
  lineChannelSecret String?
  lineAccessToken  String?
  lineNotifyToken  String?
  geofenceLat      Float?
  geofenceLng      Float?
  geofenceRadius      Float    @default(200)
  lateDeductRate      Float    @default(0)
  absentDeductRate    Float    @default(0)
  imageRetentionDays  Int      @default(90)
  probationMonths     Int      @default(3) // ช่วงทดลองงาน (เดือน) — ไม่มีพักร้อน
  outsideWorkPlanTitle String? @default("แผนการดำเนินงานของบังคับคดีและทนายความประจำบริษัท") @map("outside_work_plan_title")
  updatedAt           DateTime @updatedAt

  @@map("company_settings")
}

// ── LEAVE POLICY (กำหนดวันลาตามตำแหน่ง/role) ────────

model LeavePolicy {
  id            String  @id @default(cuid())
  name          String
  role          Role?   // null = default policy ใช้กับทุก role ที่ไม่มี policy เฉพาะ
  isDefault     Boolean @default(false)
  sickDays      Int     @default(30)
  vacationDays  Int     @default(6)
  personalDays  Int     @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("leave_policies")
}

// ── FORGOT SCAN REQUEST ─────────────────────────

model ForgotScanRequest {
  id            String        @id @default(cuid())
  userId        String
  date          DateTime      // วันที่ลืมสแกน (เก็บเป็น midnight Bangkok)
  scanType      String        // checkin | lunch-out | lunch-in | checkout
  correctTime   DateTime      // เวลาที่ถูกต้อง
  reason        String
  evidenceUrl   String?       // ไฟล์หลักฐาน (optional)
  status        RequestStatus @default(PENDING)

  chainConfigId    String? @map("chain_config_id")
  currentStepOrder Int     @default(0) @map("current_step_order")

  supervisorId  String?       // legacy step 1
  supervisorNote String?
  supervisorAt  DateTime?

  hrId          String?       // ผู้อนุมัติขั้น 2 (HR)
  hrNote        String?
  hrAt          DateTime?

  originalTime  DateTime?     // เวลาเดิมก่อนแก้ (audit log)
  attendanceId  String?       // อ้างอิง Attendance row ที่ถูกแก้
  appliedAt     DateTime?     // เวลาที่ระบบ apply แล้ว

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation("ForgotScanUser", fields: [userId], references: [id])
  supervisorRel User?         @relation("ForgotScanSupervisor", fields: [supervisorId], references: [id])
  hrRel         User?         @relation("ForgotScanHR", fields: [hrId], references: [id])
  chainConfig   ApprovalChainConfig? @relation("ForgotScanChain", fields: [chainConfigId], references: [id])
  stepLogs      ForgotScanApprovalStep[]

  @@map("forgot_scan_requests")
}

// ── TASK ASSIGNMENT ──────────────────────────────

model TaskAssignment {
  id           String       @id @default(cuid())
  title        String
  description  String?
  type         TaskType     @default(OFFICE)
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(PENDING)

  assigneeId   String       @map("assignee_id")
  assignedById String       @map("assigned_by_id")

  startDate    DateTime?    @map("start_date")
  dueDate      DateTime?    @map("due_date")

  notes        String?
  attachmentUrl String?     @map("attachment_url")

  resultNote   String?      @map("result_note")
  resultUrl    String?      @map("result_url")
  submittedAt  DateTime?    @map("submitted_at")

  reviewNote   String?      @map("review_note")
  reviewedAt   DateTime?    @map("reviewed_at")
  reviewedById String?      @map("reviewed_by_id")

  taskLinks     String?      @map("task_links")
  progressNotes String?      @map("progress_notes")

  // Phase 1 — department workflow fields
  caseNumber       String?   @map("case_number")
  clientName       String?   @map("client_name")
  taskDepartment   String?   @map("task_department")
  appointmentDate  DateTime? @map("appointment_date")
  courtDate        DateTime? @map("court_date")
  appointmentPlace String?   @map("appointment_place")

  // Phase 5 — client portal link
  clientId         String?   @map("client_id")
  // Phase 9 — Client CRM
  clientCompanyId  String?   @map("client_company_id")

  // Phase 2 — Deadline & SLA
  dueTime      String?   @map("due_time")      // HH:MM for reminder targeting
  slaHours     Int?      @map("sla_hours")     // SLA target hours from creation
  slaDeadline  DateTime? @map("sla_deadline")  // computed: createdAt + slaHours

  // Phase 3 — Template, Case Relation & Automation
  templateId    String? @map("template_id")    // which template generated this task
  debtorId      String? @map("debtor_id")      // primary debtor link (plain ref, no FK constraint)
  rejectedCount Int     @default(0) @map("rejected_count") // times rejected — triggers CEO alert at 3+

  // Case Management — FK to Case entity
  caseId        String? @map("case_id")

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  assignee        User              @relation("TaskAssignee", fields: [assigneeId],   references: [id])
  assignedBy      User              @relation("TaskAssigner", fields: [assignedById], references: [id])
  reviewedBy      User?             @relation("TaskReviewer", fields: [reviewedById], references: [id])
  client          User?             @relation("TaskClient",   fields: [clientId],     references: [id])
  clientCompany   ClientCompany?    @relation(fields: [clientCompanyId], references: [id])
  template        TaskTemplate?     @relation(fields: [templateId], references: [id])
  case            Case?             @relation(fields: [caseId],     references: [id])
  attachments     TaskAttachment[]
  statusHistories CaseStatusHistory[]
  clientMessages  ClientMessage[]
  caseIncomes     CaseIncome[]
  caseExpenses    CaseExpense[]
  expenseClaims   ExpenseClaim[]
  debtors         Debtor[]
  slaRecords      ClientSlaRecord[]
  billingInvoices BillingInvoice[]
  comments        TaskComment[]
  checklist       TaskChecklist[]
  timeline        TaskTimeline[]
  dependencies    TaskDependency[]  @relation("TaskDeps")
  dependents      TaskDependency[]  @relation("TaskBlockedBy")

  @@map("task_assignments")
}

// ── TASK ATTACHMENTS ─────────────────────────────

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String   @map("task_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  publicId     String   @map("public_id")
  fileType     String   @map("file_type")
  fileSize     Int?     @map("file_size")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now())

  task         TaskAssignment @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User           @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@map("task_attachments")
}

// ── TASK COMMENTS (Phase 2) ──────────────────────────

model TaskComment {
  id           String   @id @default(cuid())
  taskId       String   @map("task_id")
  userId       String   @map("user_id")
  content      String
  parentId     String?  @map("parent_id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task    TaskAssignment @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User           @relation("TaskCommentAuthor", fields: [userId], references: [id])
  parent  TaskComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies TaskComment[]  @relation("CommentReplies")

  @@map("task_comments")
}

// ── TASK CHECKLIST (Phase 2) ──────────────────────────

model TaskChecklist {
  id            String    @id @default(cuid())
  taskId        String    @map("task_id")
  title         String
  isCompleted   Boolean   @default(false) @map("is_completed")
  order         Int       @default(0)
  completedById String?   @map("completed_by_id")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  task        TaskAssignment @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy User?          @relation("TaskChecklistCompleter", fields: [completedById], references: [id])

  @@map("task_checklists")
}

// ── TASK TIMELINE / AUDIT TRAIL (Phase 2) ────────────────────────────────────

model TaskTimeline {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  action      String   // created | status_changed | edited | commented | checklist_completed | attachment_uploaded | escalated
  description String
  meta        String?  // JSON: { oldStatus, newStatus, field, oldValue, newValue }
  createdAt   DateTime @default(now()) @map("created_at")

  task TaskAssignment @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User           @relation("TaskTimelineActor", fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_timelines")
}

// ── TASK TEMPLATES (Phase 3) ────────────────────────────────────────────────

model TaskTemplate {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  category            String   @default("GENERAL")
  taskType            String?  @map("task_type")
  priority            String   @default("MEDIUM")
  defaultSlaHours     Int?     @map("default_sla_hours")
  defaultChecklist    String   @default("[]") @map("default_checklist")
  defaultAssigneeRole String?  @map("default_assignee_role")
  department          String?
  notes               String?
  isActive            Boolean  @default(true) @map("is_active")
  sortOrder           Int      @default(0) @map("sort_order")
  createdById         String   @map("created_by_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  createdBy User             @relation("TemplateCreator", fields: [createdById], references: [id])
  tasks     TaskAssignment[]

  @@index([category])
  @@index([isActive])
  @@map("task_templates")
}

// ── TASK DEPENDENCIES (Phase 3) ─────────────────────────────────────────────

model TaskDependency {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  dependsOnId String   @map("depends_on_id")
  createdAt   DateTime @default(now()) @map("created_at")

  task      TaskAssignment @relation("TaskDeps",      fields: [taskId],      references: [id], onDelete: Cascade)
  dependsOn TaskAssignment @relation("TaskBlockedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

// ── TASK AUTOMATION RULES (Phase 3) ─────────────────────────────────────────

model TaskAutomationRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerOn   String   @map("trigger_on")
  conditions  String   @default("{}")
  action      String
  actionData  String   @default("{}") @map("action_data")
  department  String?
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("task_automation_rules")
}

// ── CASE DOCUMENT CENTER (Phase 4) ──────────────────

model CaseDocument {
  id           String    @id @default(cuid())
  title        String
  description  String?
  docType      String    @default("OTHER") @map("doc_type")
  category     String    @default("OTHER")
  caseNumber   String?   @map("case_number")
  clientName   String?   @map("client_name")
  department   String?
  taskId       String?   @map("task_id")
  assignedToId String?   @map("assigned_to_id")
  uploadedById String    @map("uploaded_by_id")
  // Phase 5 — client portal link
  clientId     String?   @map("client_id")
  status       String    @default("ACTIVE")
  tags         String?
  isArchived   Boolean   @default(false) @map("is_archived")
  // Document Center Phase 1 — FK to Case + Debtor
  caseId       String?   @map("case_id")
  debtorId     String?   @map("debtor_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  uploadedBy User                    @relation("CaseDocUploader",  fields: [uploadedById],  references: [id])
  assignedTo User?                   @relation("CaseDocAssignee",  fields: [assignedToId],  references: [id])
  client     User?                   @relation("DocClient",         fields: [clientId],      references: [id])
  case       Case?                   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  files      CaseDocumentFile[]
  signatures CaseDocumentSignature[]
  versions   CaseDocumentVersion[]

  @@index([caseId])
  @@index([category])
  @@index([isArchived])
  @@map("case_documents")
}

model CaseDocumentFile {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  secureUrl    String?  @map("secure_url")
  publicId     String   @map("public_id")
  fileType     String   @map("file_type")
  mimeType     String?  @map("mime_type")
  resourceType String?  @map("resource_type")
  format       String?
  fileSize     Int?     @map("file_size")
  version      Int      @default(1)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  document   CaseDocument @relation(fields: [documentId],   references: [id], onDelete: Cascade)
  uploadedBy User         @relation("CaseDocFileUploader", fields: [uploadedById], references: [id])

  @@map("case_document_files")
}

model CaseDocumentSignature {
  id             String   @id @default(cuid())
  documentId     String   @map("document_id")
  signedById     String   @map("signed_by_id")
  signerName     String   @map("signer_name")
  signerRole     String   @map("signer_role")
  signerPosition String?  @map("signer_position")
  signatureType  String   @default("TYPED") @map("signature_type")
  signatureData  String?  @map("signature_data")
  signatureUrl   String?  @map("signature_url")
  typedName      String?  @map("typed_name")
  signedAt       DateTime @default(now()) @map("signed_at")

  document CaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signedBy User         @relation("CaseDocSigner",    fields: [signedById], references: [id])

  @@map("case_document_signatures")
}

model CaseDocumentVersion {
  id            String   @id @default(cuid())
  documentId    String   @map("document_id")
  versionNumber Int      @map("version_number")
  changeNote    String?  @map("change_note")
  changedById   String   @map("changed_by_id")
  changedByName String   @map("changed_by_name")
  createdAt     DateTime @default(now()) @map("created_at")

  document  CaseDocument @relation(fields: [documentId],  references: [id], onDelete: Cascade)
  changedBy User         @relation("CaseDocVersioner", fields: [changedById], references: [id])

  @@map("case_document_versions")
}

// ── PHASE 5 — CLIENT PORTAL ──────────────────────────

model CaseStatusHistory {
  id            String   @id @default(cuid())
  taskId        String   @map("task_id")
  status        String
  note          String?
  changedById   String?  @map("changed_by_id")
  changedByName String   @default("") @map("changed_by_name")
  createdAt     DateTime @default(now())

  task      TaskAssignment @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User?          @relation("StatusHistoryChanger", fields: [changedById], references: [id])

  @@map("case_status_history")
}

model ClientMessage {
  id           String    @id @default(cuid())
  clientId     String    @map("client_id")
  taskId       String?   @map("task_id")
  senderId     String?   @map("sender_id")
  senderName   String    @map("sender_name")
  isFromClient Boolean   @default(true) @map("is_from_client")
  content      String
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now())

  client User            @relation("ClientMessages", fields: [clientId], references: [id])
  sender User?           @relation("MessageSender",  fields: [senderId],  references: [id])
  task   TaskAssignment? @relation(fields: [taskId],   references: [id])

  @@map("client_messages")
}

// ── PHASE 7 — CASE FINANCIAL MANAGEMENT ─────────────────

model CaseIncome {
  id          String   @id @default(cuid())
  taskId      String?  @map("task_id")
  caseNumber  String?  @map("case_number")
  clientName  String?  @map("client_name")
  incomeType  String   @map("income_type")
  amount      Float
  date        DateTime
  note        String?
  department  String?
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task      TaskAssignment? @relation(fields: [taskId],      references: [id])
  createdBy User            @relation("CaseIncomeCreator",   fields: [createdById], references: [id])

  @@map("case_incomes")
}

model CaseExpense {
  id          String   @id @default(cuid())
  taskId      String?  @map("task_id")
  caseNumber  String?  @map("case_number")
  expenseType String   @map("expense_type")
  amount      Float
  date        DateTime
  employeeId  String   @map("employee_id")
  note        String?
  receiptUrl  String?  @map("receipt_url")
  department  String?
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task      TaskAssignment? @relation(fields: [taskId],        references: [id])
  employee  User            @relation("CaseExpenseEmployee",   fields: [employeeId],  references: [id])
  createdBy User            @relation("CaseExpenseCreator",    fields: [createdById], references: [id])

  @@map("case_expenses")
}

model ExpenseClaim {
  id             String    @id @default(cuid())
  title          String
  taskId         String?   @map("task_id")
  caseNumber     String?   @map("case_number")
  expenseType    String    @map("expense_type")
  amount         Float
  date           DateTime
  note           String?
  status         String    @default("PENDING")
  submittedById  String    @map("submitted_by_id")
  supervisorNote String?   @map("supervisor_note")
  ceoNote        String?   @map("ceo_note")
  rejectedNote   String?   @map("rejected_note")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  task        TaskAssignment?   @relation(fields: [taskId],        references: [id])
  submittedBy User              @relation("ClaimSubmitter",        fields: [submittedById], references: [id])
  files       ExpenseClaimFile[]

  @@map("expense_claims")
}

model ExpenseClaimFile {
  id        String   @id @default(cuid())
  claimId   String   @map("claim_id")
  url       String
  publicId  String   @default("") @map("public_id")
  filename  String
  fileType  String   @map("file_type")
  size      Int      @default(0)
  createdAt DateTime @default(now())

  claim ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("expense_claim_files")
}

// ── PHASE 8 — DEBT COLLECTION CRM ────────────────────────────

model Debtor {
  id            String    @id @default(cuid())
  debtorNumber  String    @unique @map("debtor_number")
  caseNumber    String?   @map("case_number")
  taskId        String?   @map("task_id")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  nationalId    String?   @map("national_id")
  phone         String?
  phone2        String?
  lineId        String?   @map("line_id")
  email         String?
  address       String?
  province      String?
  assignedToId  String?   @map("assigned_to_id")
  status        String    @default("NEW")
  totalDebt     Float     @default(0) @map("total_debt")
  paidAmount    Float     @default(0) @map("paid_amount")
  remainingDebt Float     @default(0) @map("remaining_debt")
  startDate     DateTime? @map("start_date")
  note          String?
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // CRM Phase 1 extensions
  phone3               String?   @map("phone3")
  facebook             String?
  workplace            String?
  occupation           String?
  incomeEstimate       Float?    @map("income_estimate")
  riskLevel            String    @default("MEDIUM") @map("risk_level")
  preferredContactTime String?   @map("preferred_contact_time")
  contactPreference    String?   @map("contact_preference")
  tags                 String    @default("[]")
  workplaceAddress     String?   @map("workplace_address")
  registeredAddress    String?   @map("registered_address")
  assetAddress         String?   @map("asset_address")
  lastContactAt        DateTime? @map("last_contact_at")

  task         TaskAssignment?      @relation(fields: [taskId],      references: [id])
  assignedTo   User?                @relation("DebtorAssignee",      fields: [assignedToId], references: [id])
  createdBy    User                 @relation("DebtorCreator",       fields: [createdById],  references: [id])
  followUps    DebtFollowUp[]
  payments     DebtPayment[]
  appointments PaymentAppointment[]
  files        DebtorFile[]
  contacts         DebtorContact[]
  promises         PromiseToPay[]
  recoveryPayments RecoveryPayment[]

  @@index([status])
  @@index([assignedToId])
  @@index([riskLevel])
  @@map("debtors")
}

model DebtFollowUp {
  id            String    @id @default(cuid())
  debtorId      String    @map("debtor_id")
  method        String
  followedAt    DateTime  @map("followed_at")
  result        String
  note          String?
  nextFollowUp  DateTime? @map("next_follow_up")
  performedById String    @map("performed_by_id")
  createdAt     DateTime  @default(now())

  debtor      Debtor @relation(fields: [debtorId],      references: [id], onDelete: Cascade)
  performedBy User   @relation("FollowUpPerformer",     fields: [performedById], references: [id])

  @@index([debtorId])
  @@index([followedAt])
  @@map("debt_follow_ups")
}

model DebtPayment {
  id           String   @id @default(cuid())
  debtorId     String   @map("debtor_id")
  amount       Float
  paidAt       DateTime @map("paid_at")
  channel      String
  receivedById String?  @map("received_by_id")
  slipUrl      String?  @map("slip_url")
  slipPublicId String?  @map("slip_public_id")
  note         String?
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now())

  debtor     Debtor @relation(fields: [debtorId],    references: [id], onDelete: Cascade)
  receivedBy User?  @relation("PaymentReceiver",     fields: [receivedById], references: [id])
  createdBy  User   @relation("PaymentCreator",      fields: [createdById],  references: [id])

  @@index([debtorId])
  @@map("debt_payments")
}

model PaymentAppointment {
  id           String   @id @default(cuid())
  debtorId     String   @map("debtor_id")
  appointDate  DateTime @map("appoint_date")
  agreedAmount Float    @map("agreed_amount")
  location     String?
  note         String?
  status       String   @default("PENDING")
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  debtor    Debtor @relation(fields: [debtorId],   references: [id], onDelete: Cascade)
  createdBy User   @relation("AppointmentCreator", fields: [createdById], references: [id])

  @@index([debtorId])
  @@index([appointDate])
  @@map("payment_appointments")
}

model DebtorFile {
  id          String   @id @default(cuid())
  debtorId    String   @map("debtor_id")
  url         String
  publicId    String   @default("") @map("public_id")
  filename    String
  fileType    String   @map("file_type")
  size        Int      @default(0)
  docType     String   @default("OTHER") @map("doc_type")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now())

  debtor    Debtor @relation(fields: [debtorId],   references: [id], onDelete: Cascade)
  createdBy User   @relation("DebtorFileCreator",  fields: [createdById], references: [id])

  @@index([debtorId])
  @@map("debtor_files")
}

// ── PHASE 8b — CRM CONTACT TIMELINE & PROMISES ───────────────────

model DebtorContact {
  id             String    @id @default(cuid())
  debtorId       String    @map("debtor_id")
  channel        String    // PHONE, LINE, SMS, EMAIL, VISIT
  direction      String    @default("OUTBOUND") // OUTBOUND, INBOUND
  result         String    // REACHED, NO_ANSWER, WRONG_NUMBER, DISCONNECTED, REFUSED, LEFT_MESSAGE
  note           String?
  duration       Int?      // seconds (for calls)
  promisedAt     DateTime? @map("promised_at")
  promisedAmount Float?    @map("promised_amount")
  nextContactAt  DateTime? @map("next_contact_at")
  performedById  String    @map("performed_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  debtor      Debtor @relation(fields: [debtorId],      references: [id], onDelete: Cascade)
  performedBy User   @relation("ContactPerformer",      fields: [performedById], references: [id])

  @@index([debtorId])
  @@index([createdAt])
  @@map("debtor_contacts")
}

model PromiseToPay {
  id             String    @id @default(cuid())
  debtorId       String    @map("debtor_id")
  promisedAmount Float     @map("promised_amount")
  promisedDate   DateTime  @map("promised_date")
  actualAmount   Float?    @map("actual_amount")
  actualDate     DateTime? @map("actual_date")
  status         String    @default("PENDING") // PENDING, KEPT, PARTIALLY_KEPT, BROKEN, CANCELLED
  note           String?
  createdById    String    @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  debtor           Debtor            @relation(fields: [debtorId],   references: [id], onDelete: Cascade)
  createdBy        User              @relation("PromiseCreator",     fields: [createdById], references: [id])
  recoveryPayments RecoveryPayment[]

  @@index([debtorId])
  @@index([promisedDate])
  @@map("promises_to_pay")
}

// ── PHASE 9 — CLIENT CRM ────────────────────────────────────────

model ClientCompany {
  id          String    @id @default(cuid())
  clientCode  String    @unique @map("client_code")
  companyName String    @map("company_name")
  contactName String?   @map("contact_name")
  phone       String?
  email       String?
  lineId      String?   @map("line_id")
  address     String?
  taxId       String?   @map("tax_id")
  clientType  String    @default("CORPORATE") @map("client_type")
  status      String    @default("ACTIVE")
  creditLimit Float?    @map("credit_limit")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  note        String?
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  createdBy           User                    @relation("ClientCompanyCreator", fields: [createdById], references: [id])
  contracts           ClientContract[]
  slaRecords          ClientSlaRecord[]
  files               ClientCompanyFile[]
  tasks               TaskAssignment[]
  invoices            BillingInvoice[]
  recoveryPayments    RecoveryPayment[]
  portalUsers         ClientPortalUser[]
  outsideWorkRequests OutsideWorkRequest[]

  @@index([status])
  @@map("client_companies")
}

// ── CLIENT PORTAL PHASE 1 ─────────────────────────────────────────────────────

model ClientPortalUser {
  id              String    @id @default(cuid())
  clientCompanyId String    @map("client_company_id")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  phone           String?
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  clientCompany ClientCompany      @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  logs          ClientPortalLog[]

  @@index([clientCompanyId])
  @@index([email])
  @@map("client_portal_users")
}

model ClientPortalLog {
  id             String   @id @default(cuid())
  portalUserId   String   @map("portal_user_id")
  action         String
  resourceType   String?  @map("resource_type")
  resourceId     String?  @map("resource_id")
  meta           String?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  portalUser ClientPortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  @@index([portalUserId])
  @@index([createdAt])
  @@map("client_portal_logs")
}

model ClientContract {
  id              String   @id @default(cuid())
  clientCompanyId String   @map("client_company_id")
  contractNumber  String   @unique @map("contract_number")
  serviceType     String   @map("service_type")
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  value           Float    @default(0)
  slaAgreement    String?  @map("sla_agreement")
  paymentTerms    String?  @map("payment_terms")
  status          String   @default("ACTIVE")
  note            String?
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  clientCompany ClientCompany       @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("ClientContractCreator",  fields: [createdById], references: [id])
  files         ClientCompanyFile[]
  slaRecords    ClientSlaRecord[]

  @@index([clientCompanyId])
  @@index([endDate])
  @@map("client_contracts")
}

model ClientSlaRecord {
  id              String    @id @default(cuid())
  clientCompanyId String    @map("client_company_id")
  contractId      String?   @map("contract_id")
  taskId          String?   @map("task_id")
  slaType         String    @map("sla_type")
  targetHours     Float     @map("target_hours")
  actualHours     Float?    @map("actual_hours")
  met             Boolean?
  note            String?
  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  resolvedAt      DateTime? @map("resolved_at")

  clientCompany ClientCompany   @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  contract      ClientContract? @relation(fields: [contractId],      references: [id])
  task          TaskAssignment? @relation(fields: [taskId],          references: [id])
  createdBy     User            @relation("SlaRecordCreator",        fields: [createdById], references: [id])

  @@index([clientCompanyId])
  @@map("client_sla_records")
}

model ClientCompanyFile {
  id              String   @id @default(cuid())
  clientCompanyId String   @map("client_company_id")
  contractId      String?  @map("contract_id")
  url             String
  publicId        String   @default("") @map("public_id")
  filename        String
  fileType        String   @map("file_type")
  size            Int      @default(0)
  docType         String   @default("OTHER") @map("doc_type")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now())

  clientCompany ClientCompany   @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  contract      ClientContract? @relation(fields: [contractId],      references: [id])
  createdBy     User            @relation("ClientCompanyFileCreator", fields: [createdById], references: [id])

  @@index([clientCompanyId])
  @@map("client_company_files")
}

// ── PHASE 10 — BILLING & INVOICE MANAGEMENT ────────────────────────────────

model BillingInvoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique @map("invoice_number")
  clientCompanyId String?   @map("client_company_id")
  clientName      String    @map("client_name")
  clientTaxId     String?   @map("client_tax_id")
  clientAddress   String?   @map("client_address")
  taskId          String?   @map("task_id")
  serviceType     String    @map("service_type")
  lineItems       String    @default("[]") @map("line_items")
  subtotal        Float     @default(0)
  vatRate         Float     @default(0.07) @map("vat_rate")
  vatAmount       Float     @default(0) @map("vat_amount")
  whtRate         Float     @default(0) @map("wht_rate")
  whtAmount       Float     @default(0) @map("wht_amount")
  totalAmount     Float     @default(0) @map("total_amount")
  status          String    @default("DRAFT")
  issueDate       DateTime  @map("issue_date")
  dueDate         DateTime  @map("due_date")
  paidAmount      Float     @default(0) @map("paid_amount")
  remainingAmount Float     @default(0) @map("remaining_amount")
  note            String?
  createdById     String    @map("created_by_id")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  clientCompany ClientCompany?   @relation(fields: [clientCompanyId], references: [id])
  task          TaskAssignment?  @relation(fields: [taskId],          references: [id])
  createdBy     User             @relation("InvoiceCreator",  fields: [createdById],  references: [id])
  approvedBy    User?            @relation("InvoiceApprover", fields: [approvedById], references: [id])
  payments      BillingPayment[]
  receipts      BillingReceipt[]

  @@index([status])
  @@index([clientCompanyId])
  @@index([dueDate])
  @@map("billing_invoices")
}

model BillingPayment {
  id            String   @id @default(cuid())
  invoiceId     String   @map("invoice_id")
  amount        Float
  paidAt        DateTime @map("paid_at")
  paymentMethod String   @map("payment_method")
  bankAccount   String?  @map("bank_account")
  slipUrl       String?  @map("slip_url")
  slipPublicId  String?  @map("slip_public_id")
  receivedById  String?  @map("received_by_id")
  note          String?
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  invoice    BillingInvoice @relation(fields: [invoiceId],    references: [id], onDelete: Cascade)
  receivedBy User?          @relation("BillingPaymentReceiver", fields: [receivedById], references: [id])
  createdBy  User           @relation("BillingPaymentCreator",  fields: [createdById],  references: [id])
  receipts   BillingReceipt[]

  @@index([invoiceId])
  @@map("billing_payments")
}

model BillingReceipt {
  id            String   @id @default(cuid())
  receiptNumber String   @unique @map("receipt_number")
  invoiceId     String   @map("invoice_id")
  paymentId     String?  @map("payment_id")
  amount        Float
  vatAmount     Float    @default(0) @map("vat_amount")
  whtAmount     Float    @default(0) @map("wht_amount")
  totalAmount   Float    @map("total_amount")
  receiverName  String   @map("receiver_name")
  issuedAt      DateTime @map("issued_at")
  note          String?
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  invoice   BillingInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment   BillingPayment? @relation(fields: [paymentId], references: [id])
  createdBy User            @relation("BillingReceiptCreator", fields: [createdById], references: [id])

  @@index([invoiceId])
  @@map("billing_receipts")
}

// Add back-relation from TaskAssignment to BillingInvoice
// (handled via BillingInvoice.task relation above — TaskAssignment gets invoices[] back-relation below)

// ── PHASE 11 — APPROVAL FLOW 2.0 ────────────────────────────────────────────

model ApprovalRequest {
  id            String   @id @default(cuid())
  docType       String   @map("doc_type")
  docId         String   @map("doc_id")
  docRef        String?  @map("doc_ref")
  title         String
  requestedById String   @map("requested_by_id")
  amount        Float?
  currentStep   Int      @default(1) @map("current_step")
  totalSteps    Int      @default(1) @map("total_steps")
  status        String   @default("PENDING")
  priority      String   @default("NORMAL")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  requestedBy User                  @relation("ApprovalRequester", fields: [requestedById], references: [id])
  steps       ApprovalRequestStep[]

  @@index([status])
  @@index([docType, docId])
  @@map("approval_requests")
}

model ApprovalRequestStep {
  id           String    @id @default(cuid())
  requestId    String    @map("request_id")
  stepOrder    Int       @map("step_order")
  stepName     String    @map("step_name")
  approverRole String?   @map("approver_role")
  approverId   String?   @map("approver_id")
  status       String    @default("PENDING")
  actorId      String?   @map("actor_id")
  comment      String?
  ip           String?
  actedAt      DateTime? @map("acted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  request  ApprovalRequest @relation(fields: [requestId],  references: [id], onDelete: Cascade)
  approver User?           @relation("StepApprover",       fields: [approverId], references: [id])
  actor    User?           @relation("StepActor",          fields: [actorId],    references: [id])

  @@index([requestId])
  @@map("approval_request_steps")
}

model DigitalSignature {
  id             String   @id @default(cuid())
  signedById     String   @map("signed_by_id")
  signerName     String   @map("signer_name")
  signerPosition String?  @map("signer_position")
  signerRole     String   @map("signer_role")
  signatureType  String   @default("TYPED") @map("signature_type")
  signatureData  String?  @map("signature_data")
  signatureUrl   String?  @map("signature_url")
  typedName      String?  @map("typed_name")
  docType        String   @map("doc_type")
  docId          String   @map("doc_id")
  ip             String?
  userAgent      String?
  signedAt       DateTime @default(now()) @map("signed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  signedBy User @relation("DigitalSignatureUser", fields: [signedById], references: [id])

  @@index([docType, docId])
  @@map("digital_signatures")
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String   @map("actor_id")
  actorName   String   @map("actor_name")
  docType     String   @map("doc_type")
  docId       String   @map("doc_id")
  docRef      String?  @map("doc_ref")
  action      String
  detail      String?
  beforeValue String?  @map("before_value")
  afterValue  String?  @map("after_value")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation("ActivityLogActor", fields: [actorId], references: [id])

  @@index([docType, docId])
  @@index([actorId])
  @@map("activity_logs")
}

// ── PHASE 12 — KNOWLEDGE BASE, SOP & TRAINING ────────────────────────────────

model KnowledgeArticle {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  content      String
  category     String    @default("GENERAL")
  department   String?
  tags         String?
  status       String    @default("DRAFT")
  viewCount    Int       @default(0)  @map("view_count")
  createdById  String    @map("created_by_id")
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdBy  User  @relation("KnowledgeCreator",  fields: [createdById],  references: [id])
  approvedBy User? @relation("KnowledgeApprover", fields: [approvedById], references: [id])

  @@index([status])
  @@index([category])
  @@map("knowledge_articles")
}

model SopDocument {
  id           String    @id @default(cuid())
  sopCode      String    @unique @map("sop_code")
  title        String
  department   String
  description  String?
  steps        String    @default("[]")
  checklist    String    @default("[]")
  relatedDocs  String    @default("[]") @map("related_docs")
  status       String    @default("DRAFT")
  version      Int       @default(1)
  note         String?
  createdById  String    @map("created_by_id")
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdBy  User         @relation("SopCreator",  fields: [createdById],  references: [id])
  approvedBy User?        @relation("SopApprover", fields: [approvedById], references: [id])
  versions   SopVersion[]

  @@index([status])
  @@index([department])
  @@map("sop_documents")
}

model SopVersion {
  id          String   @id @default(cuid())
  sopId       String   @map("sop_id")
  version     Int
  changeNote  String?  @map("change_note")
  snapshot    String?
  changedById String   @map("changed_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  sop       SopDocument @relation(fields: [sopId],         references: [id], onDelete: Cascade)
  changedBy User        @relation("SopVersionCreator",     fields: [changedById], references: [id])

  @@index([sopId])
  @@map("sop_versions")
}

model TrainingModule {
  id               String   @id @default(cuid())
  title            String
  description      String?
  department       String?
  contentType      String   @default("DOCUMENT") @map("content_type")
  contentUrl       String?  @map("content_url")
  coverUrl         String?  @map("cover_url")
  targetRoles      String   @default("[]") @map("target_roles")
  estimatedMinutes Int      @default(30) @map("estimated_minutes")
  passingScore     Int      @default(70) @map("passing_score")
  isRequired       Boolean  @default(false) @map("is_required")
  status           String   @default("DRAFT")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  createdBy   User                 @relation("TrainingCreator", fields: [createdById], references: [id])
  enrollments TrainingEnrollment[]
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@index([status])
  @@map("training_modules")
}

model TrainingEnrollment {
  id               String    @id @default(cuid())
  moduleId         String    @map("module_id")
  userId           String    @map("user_id")
  status           String    @default("NOT_STARTED")
  score            Int?
  timeSpentMinutes Int       @default(0) @map("time_spent_minutes")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user   User           @relation("TrainingEnrollee", fields: [userId], references: [id])

  @@unique([moduleId, userId])
  @@index([userId])
  @@map("training_enrollments")
}

model QuizQuestion {
  id            String   @id @default(cuid())
  moduleId      String   @map("module_id")
  question      String
  options       String   @default("[]")
  questionOrder Int      @default(0) @map("question_order")
  createdAt     DateTime @default(now()) @map("created_at")

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  moduleId  String   @map("module_id")
  userId    String   @map("user_id")
  answers   String   @default("[]")
  score     Int
  passed    Boolean
  attempt   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user   User           @relation("QuizAttemptUser", fields: [userId], references: [id])

  @@index([moduleId, userId])
  @@map("quiz_attempts")
}

// ── PHASE 13 — CALENDAR & APPOINTMENTS ────────────────────────────────────────

model CalendarEvent {
  id                 String    @id @default(cuid())
  title              String
  eventType          String    @default("OTHER") @map("event_type")
  startAt            DateTime  @map("start_at")
  endAt              DateTime? @map("end_at")
  startTime          String?   @map("start_time")    // HH:MM
  endTime            String?   @map("end_time")      // HH:MM
  allDay             Boolean   @default(false) @map("all_day")
  location           String?
  locationLat        Float?    @map("location_lat")
  locationLng        Float?    @map("location_lng")
  googleMapsUrl      String?   @map("google_maps_url")
  description        String?
  courtName          String?   @map("court_name")
  caseNumber         String?   @map("case_number")
  clientName         String?   @map("client_name")
  debtorName         String?   @map("debtor_name")
  debtAmount         Float?    @map("debt_amount")
  status             String    @default("SCHEDULED")
  priority           String    @default("MEDIUM")
  department         String?
  attendees          String    @default("[]")
  attachments        String    @default("[]")
  note               String?
  reminderEnabled    Boolean   @default(true) @map("reminder_enabled")
  reminderSentAt     DateTime? @map("reminder_sent_at")
  // Court Calendar Phase 1 — FK links
  caseId             String?   @map("case_id")
  courtId            String?   @map("court_id")
  assignedLawyerId   String?   @map("assigned_lawyer_id")
  assignedEmployeeId String?   @map("assigned_employee_id")
  createdById        String    @map("created_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  createdBy User   @relation("CalendarEventCreator", fields: [createdById], references: [id])
  case      Case?  @relation("CalendarEventCase", fields: [caseId], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([eventType])
  @@index([status])
  @@index([createdById])
  @@index([caseId])
  @@index([assignedLawyerId])
  @@map("calendar_events")
}

// ── PHASE 15 — ENTERPRISE SECURITY ─────────────

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  ip         String?
  userAgent  String?
  success    Boolean  @default(false)
  userId     String?
  reason     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId])
  @@map("login_attempts")
}

model SecurityEvent {
  id          String   @id @default(cuid())
  userId      String?
  eventType   String
  severity    String   @default("INFO")
  description String
  ip          String?
  userAgent   String?
  metadata    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([severity])
  @@index([eventType])
  @@map("security_events")
}

model DeviceSession {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   @unique
  ip          String?
  userAgent   String?
  browser     String?
  os          String?
  deviceType  String?
  country     String?
  isRevoked   Boolean  @default(false)
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("device_sessions")
}

model OtpCode {
  id         String   @id @default(cuid())
  userId     String
  challenge  String   @unique
  code       String
  channel    String   @default("LINE")
  purpose    String   @default("TWO_FA_LOGIN")
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
  @@index([challenge])
  @@map("otp_codes")
}

model TwoFactorSetup {
  id         String   @id @default(cuid())
  userId     String   @unique
  enabled    Boolean  @default(false)
  channel    String   @default("LINE")
  totpSecret String?  @map("totp_secret")
  enabledAt  DateTime? @map("enabled_at")
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_setups")
}

model BackupRecord {
  id          String   @id @default(cuid())
  filename    String
  sizeBytes   Int      @default(0) @map("size_bytes")
  tables      String
  status      String   @default("COMPLETED")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now())
  note        String?

  @@index([createdAt])
  @@map("backup_records")
}

// ── CASE MANAGEMENT ──────────────────────────────────────────────────────────

model CaseNumberSeq {
  year Int @id
  last Int @default(0)

  @@map("case_number_seqs")
}

model Case {
  id                 String       @id @default(cuid())
  caseNumber         String       @unique @map("case_number")
  caseTitle          String       @map("case_title")
  caseType           CaseType     @map("case_type")
  status             CaseStatus   @default(NEW)
  priority           CasePriority @default(MEDIUM)
  description        String?
  debtAmount         Float?       @map("debt_amount")
  department         String?
  assignedEmployeeId String?      @map("assigned_employee_id")
  createdById        String       @map("created_by_id")
  openedAt           DateTime     @default(now()) @map("opened_at")
  closedAt           DateTime?    @map("closed_at")
  dueDate            DateTime?    @map("due_date")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Phase 2 fields
  riskLevel        String    @default("MEDIUM") @map("risk_level")
  slaDeadline      DateTime? @map("sla_deadline")
  templateId       String?   @map("template_id")
  collectedAmount  Float     @default(0) @map("collected_amount")
  legalFee         Float     @default(0) @map("legal_fee")
  courtFee         Float     @default(0) @map("court_fee")
  enforcementFee   Float     @default(0) @map("enforcement_fee")

  assignedEmployee User?          @relation("CaseAssignee",  fields: [assignedEmployeeId], references: [id])
  createdBy        User           @relation("CaseCreator",   fields: [createdById],        references: [id])
  template         CaseTemplate?  @relation(fields: [templateId], references: [id])
  client           CaseClient?
  debtor           CaseDebtor?
  courts           CaseCourt[]
  timeline         CaseTimeline[]
  tasks            TaskAssignment[]
  checklists       CaseChecklist[]
  debtorActivities CaseDebtorActivity[]
  financial        CaseFinancial?
  documents        CaseDocument[]
  recoveryPayments RecoveryPayment[]
  calendarEvents   CalendarEvent[] @relation("CalendarEventCase")
  courtEvents      CourtEvent[]

  @@index([status])
  @@index([caseType])
  @@index([priority])
  @@index([riskLevel])
  @@index([assignedEmployeeId])
  @@index([createdAt])
  @@map("cases")
}

model CaseClient {
