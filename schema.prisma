datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MANAGER_HR
  ADMIN
  EMPLOYEE
  LAWYER
}

enum SSOStatus {
  IN_SSO
  OUT_SSO
}

model Company {
  id           String          @id @default(cuid())
  name         String
  users        User[]
  rules        CompanyRule[]
  settings     CompanySettings?
  weeklyPlans  WeeklyPlan[]
  attendances  Attendance[]
  announcements Announcement[]
  leaveBalances LeaveBalance[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(EMPLOYEE)
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  ssoStatus     SSOStatus @default(IN_SSO)
  lineId        String?   @unique
  department    String?
  isCoworker    Boolean   @default(false)

  // Relations
  attendances   Attendance[]
  leaves        LeaveRequest[]
  payrolls      Payroll[]
  warnings      Warning[]
  lawyerPlans   WeeklyPlan[]    @relation("LawyerPlan")
  leaveBalances LeaveBalance[]

  createdAt     DateTime  @default(now())
}

model Attendance {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  checkIn       DateTime @default(now())
  checkOut      DateTime?
  lunchOut      DateTime?
  lunchIn       DateTime?
  totalWorkMinutes  Int?
  totalBreakMinutes Int?
  workPhase     String?  // "working" | "lunch_break" | "checked_out"
  locationType  String   // "IN_OFFICE" | "OUT_OF_OFFICE"
  coordinates   Json     // { lat: number, lng: number }
  facePhoto     String   // Cloudinary URL
  faceVerified  Boolean  @default(false)  // ผ่านการจับคู่ใบหน้า (face matching) หรือไม่
  faceConfidence Float?                    // คะแนนความมั่นใจของการจับคู่ใบหน้า
  isLate        Boolean  @default(false)
}

model LeaveRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  type          String   // "SICK" | "VACATION" | "PERSONAL" | "UNPAID"
  startDate     DateTime
  endDate       DateTime
  status        String   @default("PENDING") // PENDING, ADMIN_APPROVED, FINAL_APPROVED, REJECTED
  reason        String
}

model WeeklyPlan {
  id            String   @id @default(cuid())
  lawyerId      String
  lawyer        User     @relation("LawyerPlan", fields: [lawyerId], references: [id])
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  weekDate      DateTime
  planDetails   String
  adminStatus   String   @default("PENDING") // PENDING, APPROVED, REJECTED
  managerStatus String   @default("PENDING")
  submittedAt   DateTime @default(now())
}

model Payroll {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  month         Int
  year          Int
  baseSalary    Float
  deduction     Float    // หักขาดลามาสาย
  bonus         Float    @default(0)
  netPay        Float
  pdfUrl        String?
  isSentToLine  Boolean  @default(false)
}

model Warning {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  reason        String
  severityLevel Int      @default(1) // สะสมใบเตือน
  createdAt     DateTime @default(now())
}

model CompanyRule {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  title     String
  fileUrl   String
}

model CompanySettings {
  id           String   @id @default(cuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id])
  lat          Float?
  lng          Float?
  radius       Int      @default(200)
  lineToken    String?
  workStartTime String? @default("08:30")
  workEndTime   String? @default("17:00")
  lateGraceMin  Int     @default(5)
  sickDaysYear  Int     @default(30)
  vacDaysYear   Int     @default(10)
  personalDaysYear Int  @default(3)
}

model Announcement {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  title       String
  body        String
  targetRole  String?  // null = ทุกคน, otherwise role string
  isSentToLine Boolean @default(false)
  createdAt   DateTime @default(now())
}

model LeaveBalance {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  year         Int
  sickRemain   Int      @default(30)
  vacRemain    Int      @default(10)
  personalRemain Int    @default(3)
}